    /* rdiv, ldiv – same as div (recursively) */
    %rdiv(&other):{ $inv::&bioctonion: &other%inv(); $temp::&bioctonion: &self%mul($inv); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$b; };
    %ldiv(&other):{ $inv::&bioctonion: &self%inv(); $temp::&bioctonion: &other%mul($inv); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$b; };
    /* addassign, laddassign, raddassign */
    %addassign(&other):{ $a::&biquaternion: &self$a + &other$a; $b::&biquaternion: &self$b + &other$b; };
    %laddassign(&other):{ $a::&biquaternion: &self$a + &other$a; $b::&biquaternion: &self$b + &other$b; };
    %raddassign(&other):{ $a::&biquaternion: &self$a + &other$a; $b::&biquaternion: &self$b + &other$b; };
    /* subassign, lsubassign, rsubassign */
    %subassign(&other):{ $a::&biquaternion: &self$a - &other$a; $b::&biquaternion: &self$b - &other$ b; };
    %lsubassign(&other):{ $a::&biquaternion: &self$a - &other$a; $b::&biquaternion: &self$b - &other$ b; };
    %rsubassign(&other):{ $a::&biquaternion: &other$a - &self$a; $b::&biquaternion: &other$b - &self$ b; };
    /* mulassign, rmulassign, lmulassign */
    %mulassign(&other):{
        $temp::&bioctonion: &self%mul($other);
        $a::&biquaternion: $temp$a;
        $b::&biquaternion: $temp$b;
    };
    %rmulassign(&other):{ $temp::&bioctonion: &self%mul($other); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$b; };
    %lmulassign(&other):{ $temp::&bioctonion: &self%mul($other); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$b; };
    /* divassign, rdivassign, ldivassign */
    %divassign(&other):{
        $inv::&bioctonion: &other%inv();
        $temp::&bioctonion: &self%mul($inv);
        $a::&biquaternion: $temp$a;
        $b::&biquaternion: $temp$b;
    };
    %rdivassign(&other):{ $inv::&bioctonion: &other%inv(); $temp::&bioctonion: &self%mul($inv); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$b; };
    %ldivassign(&other):{ $inv::&bioctonion: &self%inv(); $temp::&bioctonion: &other%mul($inv); $a::&biquaternion: $temp$a; $b::&biquaternion: $temp$ b; };
    /* conj */
    %conj():{ $a::&biquaternion: &self$a%conj(); $b::&biquaternion: 0 - &self$b; };
    /* sqrt – based on norm */
    %sqrt():{ $value::&real<&N>: %sqrt(&self%norm()); };
    /* norm */
    %norm():{ $value::&real<&N>: %sqrt((&self$a* &self$a) + (&self$b * &self$b)); };
    /* inv */
    %inv():{
        $norm_sq::&real<&N>: (&self$a* &self$a) + (&self$b * &self$b);
        $conj::&bioctonion: &self%conj();
        $a::&biquaternion: $conj$a / $norm_sq;
        $b::&biquaternion: $conj$b / $norm_sq;
    };
};