&octonion<&N,&B>::?NDA:{
    /* neg */
    %neg(&self):{ $a::&quaternion: 0 - &self$a; $b::&quaternion: 0 - &self$b; };
    /* add */
    %add(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    /* ladd, radd – same as add */
    %ladd(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    %radd(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    /* sub */
    %sub(&other):{ $a::&quaternion: &self$a - &other$a; $b::&quaternion: &self$b - &other$ b; };
    /* lsub, rsub – order matters */
    %lsub(&other):{ $a::&quaternion: &self$a - &other$a; $b::&quaternion: &self$b - &other$ b; };
    %rsub(&other):{ $a::&quaternion: &other$a - &self$a; $b::&quaternion: &other$b - &self$ b; };
    /* mul – Cayley‑Dickson for 16‑dimensional elements */
    %mul(&other):{
        $a::&quaternion: (&self$a * &other$a) - ($other$b%conj() * &self$b);
        $b::&quaternion: ($other$b * &self$a) + (&self$b * &other$a%conj());
    };
    /* rmul, lmul – same as mul */
    %rmul(&other):{ $a::&quaternion: (&self$a * &other$a) - ($other$b%conj() * &self$b); $b::&quaternion: ($other$b * &self$a) + (&self$b * &other$a%conj()); };
    %lmul(&other):{ $a::&quaternion: (&self$a * &other$a) - ($other$b%conj() * &self$b); $b::&quaternion: ($other$b * &self$a) + (&self$b * &other$a%conj()); };
    /* div */
    %div(&other):{
        $inv::&octonion: &other%inv();
        $temp::&octonion: &self%mul($inv);
        $a::&quaternion: $temp$a;
        $b::&quaternion: $temp$b;
    };
    /* rdiv, ldiv – same as div (recursively) */
    %rdiv(&other):{ $inv::&octonion: &other%inv(); $temp::&octonion: &self%mul($inv); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    %ldiv(&other):{ $inv::&octonion: &self%inv(); $temp::&octonion: &other%mul($inv); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    /* addassign, laddassign, raddassign */
    %addassign(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    %laddassign(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    %raddassign(&other):{ $a::&quaternion: &self$a + &other$a; $b::&quaternion: &self$b + &other$b; };
    /* subassign, lsubassign, rsubassign */
    %subassign(&other):{ $a::&quaternion: &self$a - &other$a; $b::&quaternion: &self$b - &other$ b; };
    %lsubassign(&other):{ $a::&quaternion: &self$a - &other$a; $b::&quaternion: &self$b - &other$ b; };
    %rsubassign(&other):{ $a::&quaternion: &other$a - &self$a; $b::&quaternion: &other$b - &self$ b; };
    /* mulassign, rmulassign, lmulassign */
    %mulassign(&other):{
        $temp::&octonion: &self%mul($other);
        $a::&quaternion: $temp$a;
        $b::&quaternion: $temp$b;
    };
    %rmulassign(&other):{ $temp::&octonion: &self%mul($other); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    %lmulassign(&other):{ $temp::&octonion: &self%mul($other); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    /* divassign, rdivassign, ldivassign */
    %divassign(&other):{
        $inv::&octonion: &other%inv();
        $temp::&octonion: &self%mul($inv);
        $a::&quaternion: $temp$a;
        $b::&quaternion: $temp$b;
    };
    %rdivassign(&other):{ $inv::&octonion: &other%inv(); $temp::&octonion: &self%mul($inv); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    %ldivassign(&other):{ $inv::&octonion: &self%inv(); $temp::&octonion: &other%mul($inv); $a::&quaternion: $temp$a; $b::&quaternion: $temp$b; };
    /* conj */
    %conj():{ $a::&quaternion: &self$a%conj(); $b::&quaternion: 0 - &self$b; };
    /* sqrt – based on norm */
    %sqrt():{ $value::&real<&N>: %sqrt(&self%norm()); };
    /* norm */
    %norm():{ $value::&real<&N>: %sqrt((&self$a* &self$a) + (&self$b * &self$b)); };
    /* inv */
    %inv():{
        $norm_sq::&real<&N>: (&self$a* &self$a) + (&self$b * &self$b);
        $conj::&octonion: &self%conj();
        $a::&quaternion: $conj$a / $norm_sq;
        $b::&quaternion: $conj$b / $norm_sq;
    };
};

